{
    "$schema": "https://opencode.ai/config.json",
    "plugin": [
        "superpowers@git+https://github.com/obra/superpowers.git"
    ],
    "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "todowrite": "allow",
        "edit": "ask",
        "bash": "ask"
    },
    "lsp": true,
    "formatter": true,
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "php",
                "artisan",
                "boost:mcp"
            ]
        },
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "enabled": true
        },
        "playwright": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "-y",
                "@playwright/mcp@latest"
            ]
        },
        "shadcn": {
            "type": "local",
            "enabled": true,
            "command": [
                "npx",
                "-y",
                "shadcn@latest",
                "mcp"
            ]
        },
        "sequential-thinking": {
            "type": "local",
            "enabled": true,
            "command": [
                "C:\\Users\\MadMouse\\AppData\\Roaming\\npm\\mcp-server-sequential-thinking.cmd"
            ]
        }
    },
    "instructions": [
        "AGENTS.md",
        "docs/engineering-rules.md",
        "docs/ui-ux-rules.md",
        "docs/isp-business-rules.md"
    ]
}
