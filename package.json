{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsc && vite build",
        "dev": "vite",
        "lint": "eslint resources/js",
        "lint:fix": "eslint resources/js --fix",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write \"resources/js/**/*.{ts,tsx,css}\"",
        "format:check": "prettier --check \"resources/js/**/*.{ts,tsx,css}\"",
        "test:e2e": "node scripts/e2e-guard-matrix.mjs && php tests/e2e/setup.php && node scripts/e2e-run.mjs",
        "test:e2e:smoke": "node scripts/e2e-guard-matrix.mjs && php tests/e2e/setup.php && node scripts/e2e-run.mjs --grep @smoke"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@headlessui/react": "^2.0.0",
        "@inertiajs/react": "^2.0.0",
        "@playwright/test": "^1.61.1",
        "@tailwindcss/forms": "^0.5.3",
        "@types/node": "^22.0.0",
        "@types/react": "^18.0.28",
        "@types/react-dom": "^18.0.10",
        "@vitejs/plugin-react": "^4.2.0",
        "autoprefixer": "^10.4.12",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "eslint": "^10.6.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "laravel-vite-plugin": "^2.0.0",
        "postcss": "^8.4.31",
        "prettier": "^3.9.4",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "tailwindcss": "^3.2.1",
        "typescript": "^5.0.2",
        "typescript-eslint": "^8.62.1",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "@heroicons/react": "^2.2.0",
        "@tanstack/react-table": "^8.21.3",
        "clsx": "^2.1.1",
        "filepond": "^4.32.12",
        "filepond-plugin-file-validate-size": "^2.2.8",
        "filepond-plugin-file-validate-type": "^1.2.9",
        "filepond-plugin-image-preview": "^4.6.12",
        "react-filepond": "^7.1.3",
        "tailwind-merge": "^3.6.0"
    }
}
